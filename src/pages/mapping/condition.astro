---
import Layout from '../../layouts/Layout.astro';
import MapHeader from '../../components/MapHeader.astro';
---
<Layout title="Mapping — Condition" active="mapping">
  <MapHeader
    title="Condition"
    dspType="condition"
    fhirResource="Condition (R4) + US Core Condition-Problems / Condition-Encounter-Diagnosis"
    summary="DSP condition resources map almost directly onto FHIR Condition. The fit is near-perfect; the only extensions needed are DSP-specific metadata (spoken forms, transcript turn provenance, confidence)."
  />

  <h2>Field-by-field</h2>
  <div class="card" style="padding:0">
    <table>
      <thead><tr><th>DSP</th><th>FHIR R4</th><th>Notes</th></tr></thead>
      <tbody>
        <tr><td><code class="inline">id</code></td><td><code class="inline">Condition.id</code> or <code class="inline">identifier</code></td><td>DSP ids are internal; FHIR <code class="inline">id</code> is server-assigned.</td></tr>
        <tr><td><code class="inline">description</code></td><td><code class="inline">Condition.code.text</code></td><td>Human-readable.</td></tr>
        <tr><td><code class="inline">condition_concept.codes</code> (SNOMED / ICD-10)</td><td><code class="inline">Condition.code.coding[]</code></td><td>Multi-coded — use both SNOMED and ICD-10 codings.</td></tr>
        <tr><td><code class="inline">condition_concept.concept_id</code></td><td>Extension <code class="inline">dsp-concept-id</code></td><td>Internal Dragon concept.</td></tr>
        <tr><td><code class="inline">clinical_status</code></td><td><code class="inline">Condition.clinicalStatus</code> (valueset: <code class="inline">condition-clinical</code>)</td><td>DSP values (active / recurrence / relapse / inactive / remission / resolved / <strong>unknown</strong>) align with the FHIR valueset.</td></tr>
        <tr><td><code class="inline">verification_status</code></td><td><code class="inline">Condition.verificationStatus</code></td><td>DSP values (provisional / <strong>unconfirmed</strong> / differential / confirmed / refuted / entered-in-error) align with the FHIR valueset.</td></tr>
        <tr><td><code class="inline">category</code></td><td><code class="inline">Condition.category</code></td><td>encounter-diagnosis / problem-list-item / health-concern — direct.</td></tr>
        <tr><td><code class="inline">severity</code></td><td><code class="inline">Condition.severity</code></td><td>Bind to SNOMED 24484000/6736007/255604002.</td></tr>
        <tr><td><code class="inline">onset</code></td><td><code class="inline">Condition.onset[x]</code></td><td>Use <code class="inline">onsetDateTime</code> or <code class="inline">onsetString</code>.</td></tr>
        <tr><td><code class="inline">abatement</code></td><td><code class="inline">Condition.abatement[x]</code></td><td></td></tr>
        <tr><td><code class="inline">stage</code></td><td><code class="inline">Condition.stage</code></td><td><code class="inline">summary</code> → <code class="inline">stage.summary</code>; <code class="inline">type</code> → <code class="inline">stage.type</code>.</td></tr>
        <tr><td><code class="inline">evidence</code></td><td><code class="inline">Condition.evidence.code.text</code></td><td></td></tr>
        <tr><td><code class="inline">body_site</code></td><td><code class="inline">Condition.bodySite</code></td><td>Prefer SNOMED body structure codes.</td></tr>
        <tr><td><code class="inline">notes</code></td><td><code class="inline">Condition.note.text</code></td><td></td></tr>
        <tr><td><code class="inline">priority</code></td><td>Extension <code class="inline">dsp-resource-priority</code> (valueCode: low/medium/high)</td><td>FHIR <code class="inline">Condition</code> has no priority element; extension-only.</td></tr>
        <tr><td><code class="inline">children_resources</code> (e.g. to plans, observations)</td><td><em>Inverse</em>: related resources reference this Condition via <code class="inline">reasonReference</code>.</td><td>Preserve the reverse link via <code class="inline">Observation.focus</code>, <code class="inline">ServiceRequest.reasonReference</code>, etc.</td></tr>
        <tr><td><code class="inline">parent_resource</code></td><td><code class="inline">Condition.encounter</code> (if encounter) or extension</td><td></td></tr>
        <tr><td><code class="inline">provenance</code> (turn indices)</td><td>DSP extension <code class="inline">transcript-turn-refs</code> + <code class="inline">Provenance</code> resource</td><td>See <a href="/dsp-fhir/gaps">Gaps</a>.</td></tr>
        <tr><td><code class="inline">external_reference</code></td><td><code class="inline">identifier</code> + <code class="inline">meta.source</code> + DSP <code class="inline">linkage-confidence</code></td><td></td></tr>
      </tbody>
    </table>
  </div>

  <h2>Side-by-side example</h2>
  <div class="grid cols-2">
    <div>
      <h3>DSP</h3>
<pre><code>{`{
  "id": "condition-001",
  "context": { "content_type": "condition" },
  "description": "Moderate osteoarthritis of the right knee",
  "condition_concept": {
    "text": "Moderate osteoarthritis of the right knee",
    "codes": [
      {"system":"snomed","identifier":"239873007"},
      {"system":"icd10","identifier":"M17.11"}
    ]
  },
  "clinical_status": "active",
  "verification_status": "confirmed",
  "category": "encounter-diagnosis",
  "severity": "moderate",
  "body_site": "right knee",
  "provenance": [11,15]
}`}</code></pre>
    </div>
    <div>
      <h3>FHIR R4 (DSP-FHIR profile)</h3>
<pre><code>{`{
  "resourceType": "Condition",
  "id": "condition-001",
  "meta": { "profile": ["https://dsp-fhir.org/StructureDefinition/Condition"] },
  "clinicalStatus":   { "coding":[{"system":"http://terminology.hl7.org/CodeSystem/condition-clinical","code":"active"}] },
  "verificationStatus":{ "coding":[{"system":"http://terminology.hl7.org/CodeSystem/condition-ver-status","code":"confirmed"}] },
  "category":[{"coding":[{"system":"http://terminology.hl7.org/CodeSystem/condition-category","code":"encounter-diagnosis"}]}],
  "severity": { "coding":[{"system":"http://snomed.info/sct","code":"6736007","display":"Moderate"}] },
  "code": {
    "text": "Moderate osteoarthritis of the right knee",
    "coding": [
      {"system":"http://snomed.info/sct","code":"239873007"},
      {"system":"http://hl7.org/fhir/sid/icd-10-cm","code":"M17.11"}
    ]
  },
  "bodySite":[{"text":"right knee"}],
  "subject": {"reference":"Patient/pat-67890"},
  "encounter":{"reference":"Encounter/enc-12345"},
  "extension":[
    {"url":"https://dsp-fhir.org/StructureDefinition/transcript-turn-refs",
     "extension":[{"url":"turn","valueInteger":11},{"url":"turn","valueInteger":15}]}
  ]
}`}</code></pre>
    </div>
  </div>
</Layout>
