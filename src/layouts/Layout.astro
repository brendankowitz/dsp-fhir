---
import '../styles/global.css';

export interface Props { title?: string; active?: string; }
const { title = 'DSP ⇄ FHIR', active = '' } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

type NavLink = { href: string; label: string; key: string };
type NavGroup = { label: string; key: string; children: NavLink[] };
type NavItem = NavLink | NavGroup;

const nav: NavItem[] = [
  { href: `${base}/`, label: 'Overview', key: 'overview' },
  {
    label: 'DSP',
    key: 'dsp',
    children: [
      { href: `${base}/dsp-primer`, label: 'DSP primer',  key: 'dsp' },
      { href: `${base}/evaluation`, label: 'R4 / R5 / R6', key: 'eval' },
    ],
  },
  {
    label: 'Mapping',
    key: 'mapping',
    children: [
      { href: `${base}/mapping`, label: 'Resource mapping', key: 'mapping' },
      { href: `${base}/graphql`, label: '$graphql',         key: 'graphql' },
      { href: `${base}/example`, label: 'Worked example',   key: 'example' },
    ],
  },
  {
    label: 'Spec',
    key: 'spec',
    children: [
      { href: `${base}/ig`,          label: 'DSP-FHIR IG',      key: 'ig' },
      { href: `${base}/operations`,  label: 'Custom operations', key: 'operations' },
      { href: `${base}/terminology`, label: 'Terminology',       key: 'terminology' },
    ],
  },
  {
    label: 'Integration',
    key: 'integration',
    children: [
      { href: `${base}/interop`, label: 'Interop & layering', key: 'interop' },
      { href: `${base}/gaps`,    label: 'Gaps & extensions',  key: 'gaps' },
    ],
  },
];

const isGroup = (n: NavItem): n is NavGroup => 'children' in n;
const groupActive = (g: NavGroup) => g.children.some(c => c.key === active);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content="Mapping the Dragon Standard Payload (DSP) onto FHIR as a first-class interoperability core." />
</head>
<body>
  <a href="#main" class="skip-link">Skip to main content</a>
  <header class="site">
    <div class="container bar">
      <div class="brand"><a href={`${base}/`}>DSP <span class="dot" aria-hidden="true">⇄</span> FHIR</a></div>
      <nav aria-label="Primary">
        {nav.map(n => (
          isGroup(n) ? (
            <div class={`nav-group${groupActive(n) ? ' active' : ''}`}>
              <button type="button" aria-haspopup="true" aria-expanded="false">
                {n.label}<span class="caret" aria-hidden="true">▾</span>
              </button>
              <div class="nav-dropdown" role="menu">
                {n.children.map(c => (
                  <a role="menuitem"
                     href={c.href}
                     class={active === c.key ? 'active' : ''}
                     aria-current={active === c.key ? 'page' : undefined}>{c.label}</a>
                ))}
              </div>
            </div>
          ) : (
            <a href={n.href}
               class={active === n.key ? 'active' : ''}
               aria-current={active === n.key ? 'page' : undefined}>{n.label}</a>
          )
        ))}
      </nav>
    </div>
  </header>
  <main id="main" tabindex="-1">
    <div class="container">
      <slot />
    </div>
  </main>
  <footer class="site">
    <div class="container">
      Analysis of Microsoft Dragon Standard Payload 1.0.0 against HL7 FHIR R4 / R5 / R6.
      Not affiliated with Microsoft or HL7. Source: <a href="https://learn.microsoft.com/en-us/industry/healthcare/dragon-copilot/sdk/partner-apis/dragon-data-exchange/dragon-standard-payload/">learn.microsoft.com/dragon-standard-payload</a>.
    </div>
  </footer>
</body>
</html>
